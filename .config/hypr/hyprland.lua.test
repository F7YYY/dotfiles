--
--  READ_IN_DESCENDING_ORDER
--
--  DEFAULT: (https://github.com/hyprwm/Hyprland/blob/main/example/hyprland.lua)
--
--  NIRI FALLBACK WM
--
-------------------------------------------------------------------------------------------------------(SOURCES)--
local hyprland = {
  source = {
    "$HOME/.config/hypr/noctalia.conf",   -- AUR:noctalia-git
    "$HOME/.config/hypr/monitors.lua"     -- AUR:nwg-displays
    -- "$HOME/.config/hypr/wallust.conf",    -- AUR:wallust
  }
-------------------------------------------------------------------------------------------------------(DAEMONS)--
  --(ENVIRONMENT_VARIABLES)--
  env = {
    -- XDG_CURRENT_DESKTOP = "Hyprland",
    -- XDG_SESSION_DESKTOP = "Hyprland",
    -- HYPRCURSOR_THEME = "hyprcursor-rose-pine",
    -- HYPRCURSOR_SIZE = "24",
    -- HYPRLAND_TRACE = "1",
  }
  --(APPLICATIONS)--
  exec_once = {
    "exporter --local",
    "startups --launch",
  }
-----------------------------------------------------------------------------------------------------(VARIABLES)--
  variables = {
    SUPER   = "SUPER",    -- ANY_KEY:{SUPER|WIN|LOGO|MOD4}
    TERM    = "ghostty",
    LOCK    = "loginctl lock-sessions"    -- "hyprlock --quiet --immediate-render",
    MENU    = "noctalia msg panel-toggle launcher",
    NMCC    = "noctalia msg panel-toggle control-center",
    NMST    = "noctalia msg settings-toggle",
    FILE    = "nemo || yazi",
    NITE    = "sh -c 'pgrep -x wlsunset && pkill -x wlsunset || wlsunset'",
    --(VIM)--
    LEFT    = "H",
    DOWN    = "J",
    UP      = "K",
    RIGHT   = "L",
    --(COLORS)--
    color1  = "#primary",
    color2  = "#secondary",
    color3  = "#tertiary",
    color4  = "#surface",
    color5  = "#surface_lowest",
    color6  = "#error",
    --(fc-list : family | sort -u)--
    FONT    = "Sony Sketch EF",
    FONT_SYMBOLS  = "FiraMono Nerd Font Mono",
  }
------------------------------------------------------------------------------------------------------(CONTROLS)--
  bind = {
    --(WINDOW_CONTROLS)--
    "SUPER, ESCAPE, EXEC, TERM",
    "SUPER SHIFT, ESCAPE, EXEC, FILE",
    "SUPER, SPACE, EXEC, MENU",
    "SUPER ALT, H, EXEC, NITE",
    "SUPER, Q, killactive",
    "SUPER SHIFT, Q, EXEC, hyprctl activewindow | grep PID | awk '{print $2}' | xargs kill -9",
    "SUPER, RETURN, hyprctl reload",
    "SUPER ALT CTRL, RETURN, EXEC, hyprshutdown || hyprctl dispatch exit",
    -- "SUPER, ALT_R, EXEC, $TERM '$HOME/.config/hypr/HyprTile/sendtoggle'",
    -- "SUPER CTRL, TAB, hyprexpo:expo, toggle",           -- [toggle, select, off/disable/on/enable]
    --(SCREENCAPTURES)--
    ", PRINT, EXEC, hyprshot-gui --silent --output-folder $HOME/Pictures/Screenshots/",
    --(XF86_BRIGHTNESS)--
    ", XF86MonBrightnessUp, EXEC, brightnessctl --quiet set 10%+",
    ", XF86MonBrightnessDown, EXEC, brightnessctl --quiet set 10%-",
    --(XF86_AUDIO)--
    ", XF86AudioRaiseVolume, EXEC, pactl set-sink-volume @DEFAULT_SINK@ +5%",
    ", XF86AudioLowerVolume, EXEC, pactl set-sink-volume @DEFAULT_SINK@ -5%",
    ", XF86AudioMute, EXEC, pactl set-sink-mute @DEFAULT_SINK@ toggle",
    ", XF86AudioMicMute, EXEC, pactl set-source-mute @DEFAULT_SOURCE@ toggle",
    --(XF86_MEDIA)--
    ", XF86AudioNext, EXEC, playerctl next",
    ", XF86AudioPlay, EXEC, playerctl play-pause",
    ", XF86AudioPrev, EXEC, playerctl previous",
    ", XF86AudioStop, EXEC, playerctl stop",
    --(XF86_POWER)--
    "CONTROLALT, BACKSPACE, EXEC, wlogout",
    ", XF86PowerOff, EXEC, hyprlock & systemctl suspend",
    "SUPER, XF86PowerOff, EXEC, systemctl poweroff",
    "SUPER SHIFT, XF86PowerOff, EXEC, systemctl reboot",
    --(LAPTOP_LID)--
    ",switch:on:Lid Switch, EXEC, hyprctl dispatch dpms off",
    ",switch:off:Lid Switch, EXEC, hyprctl dispatch dpms on",
    ",switch:on:Lid Switch, EXEC, $LOCK, disable",
    ",switch:off:Lid Switch, EXEC, $LOCK, enable",
  }

  bindr = {
    "SUPER, Super_L, EXEC, .. MENU,
  }

  bind_misc = {
    { "", "XF86MonBrightnessUp", "EXEC, brightnessctl --quiet set 10%" },
    { "", "XF86MonBrightnessDown", "EXEC, brightnessctl --quiet set 10%-" },
    { "", "XF86AudioRaiseVolume", "EXEC, pactl set-sink-volume @DEFAULT_SINK@ +5%" },
    { "", "XF86AudioLowerVolume", "EXEC, pactl set-sink-volume @DEFAULT_SINK@ -5%" },
    { "", "XF86AudioMute", "EXEC, pactl set-sink-mute @DEFAULT_SINK@ toggle" },
    { "", "XF86AudioMicMute", "EXEC, pactl set-source-mute @DEFAULT_SOURCE@ toggle" },
    { "", "XF86AudioNext", "EXEC, playerctl next" },
    { "", "XF86AudioPlay", "EXEC, playerctl play-pause" },
    { "", "XF86AudioPrev", "EXEC, playerctl previous" },
  }
----------------------------------------------------------------------------------------------------(WORKSPACES)--

-------------------------------------------------------------------------------------------------------(SUBMAPS)--

---------------------------------------------------------------------------------------------(WINDOW_MANAGEMENT)--

---------------------------------------------------------------------------------------------------(PERIPHERALS)--

--------------------------------------------------------------------------------------------------------(THEMES)--
}
