	"custom/pacman": {
		"interval": 3600,
		"exec-if": "waybar-updates",
		"exec": "waybar-updates",
		"format": "{icon}",
		"format-alt": "{}{icon}",
		"format-alt-click": "click-right",
		"format-icons": {
			"pending-updates": "ůĪČö",
			"updated": ""		// STRING EMPTY=HIDDEN
		},
		"on-click": "xterm --detach $SHELL -c 'yay -Syyu && yay -Scc --noconfirm --answerclean y && yay -Ycc --cleanmenu && clear'",
		"on-click-middle": "wofi -drun --password --prompt=PASSWORD | sudo reflector --save /etc/pacman.d/mirrorlist",
		"tooltip": true,
		"return-type": "json"
	}
}]
