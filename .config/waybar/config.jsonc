/********************************************************
*  ‚Ėą‚Ėą‚ēó    ‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēó   ‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó   *
*  ‚Ėą‚Ėą‚ēĎ    ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚ēö‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó  *
*  ‚Ėą‚Ėą‚ēĎ ‚Ėą‚ēó ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ  *
*  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēĎ  ‚ēö‚Ėą‚Ėą‚ēĒ‚ēĚ  ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó  *
*  ‚ēö‚Ėą‚Ėą‚Ėą‚ēĒ‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ  *
*   ‚ēö‚ēź‚ēź‚ēĚ‚ēö‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēĚ   ‚ēö‚ēź‚ēĚ   ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēĚ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēĚ  *
*(https://github.com/Alexays/Waybar/wiki/Configuration/)*
*
*	THIS IS JUST GETTING TO MUCH, MIGRATING TO EWWW
*
**‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ(LAYOUT)‚ĒÄ‚ĒÄ‚ĒÄ*/
[{
    //"interval": 1,
	"output": "",				// STRING EMPTY=ALL
	"layer": "top",
	"position": "overlay",
	//"all-outputs": true,		// DID NOT WORK
	"gtk-layer-shell": true,
	"pango_markup": true,
	"reload_style_on_change": true,
	"height": 0,
	"width": 0,
	"margin": 0,
	"spacing": 0,
	"icon-size": 20,
	/*‚ĒÄ‚ĒÄ‚ĒÄ(FIX_ALL_MODULES_FORMAT-ALT_RIGHT_CLICK_STATUS)‚ĒÄ(POSSIBLE_WABAR_BUG)‚ĒÄ‚ĒÄ‚ĒÄ*/
	"modules-left": [			//___APPLICATIONS___
		"custom/appmenu",		// AUR: WOFI | SCRIPT: $HOME/.CONFIG/WOFI/SCRIPTS/WOFIMENU
		"sway/workspaces",		// REPLACE ‚Üī
		"sway/scratchpad",		// REPLACE ‚Üī
		"hyprland/workspaces",	// REPLACE ‚üī "wlr/workspaces",
		"tray",
		"wlr/taskbar",
		"gamemode",
		"custom/recorder"		// AUR: WF-RECORDER-GUI/OBS-STUDIO | WIP ~ SCRIPT: $HOME/.CONFIG/WAYBAR/SCRIPTS/RECORDER
	],
	"modules-center": [			//___STATUS___
		"custom/weather",		// AUR: WTTRBAR | WIP ~ FORMAT ÓćĀ/ÓĆĻ
		"custom/notification",	// AUR: SWAYNC	| WIP ~ EVERYTHING
		//"group/music",			// WIP ~ EVERYTHING
		"clock"
	],
	"modules-right": [			//___SYSTEMS___
		"group/window",			// WIP ~ EVERYTHING
		"custom/redlight",
		"bluetooth",			// WIP ~ REPORT ALL CONNECTED DEVICES
		"group/sink",
		"group/source",			// WIP ~ #SOURCE/SLIDER NOT SHOWN
		"group/backlight",
		"group/temperatures",	// WIP ~ EVERYTHING
		"group/system",
		"network",				// WIP ~ REPORT EXTERNAL-IP W/O DDOS
		"group/power",		// WIP ~ RIGHT CLICK SHOW OPTIONS (NOT HOVER) | SCRIPT: $HOME/.CONFIG/WOFI/SCRIPTS/POWERMENU
		"custom/pacman"			// AUR: WAYBAR-UPDATES
	],
/*‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ(MODULES_LEFT)‚ĒÄ‚ĒÄ‚ĒÄ*/
	"custom/appmenu": {
    	//"interval": 1,
		"format": "ůį£á",
		"format-alt": "ÔÖľ",
		"format-alt-click": "click-right",
		"on-click": "wofi",
		"on-click-middle": "$HOME/.config/wofi/SCRIPTS/WOFIMENU",
		"tooltip-format": "{}\n‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ\nūüĖĪŠź©‚Ě∂‚ćÜLAUNCHER\nūüĖĪŠź©‚Ě∑‚ćÜFORMAT\nūüĖĪŠź©‚Ěł‚ćÜOTHER",
		"tooltip": true
	},
	"sway/workspaces": {
    	//"interval": 1,
		"disable-scroll": false,
		"active-only": false,
		"all-outputs": true,
		"current-only": true,
		"sort-by-number": true,
		"show-special": true,
		"format": "{icon}",
		"format-icons": {
			"1": "ůį≤°",
			"2": "ůį≤£",
			"3": "ůį≤•",
			"4": "ůį≤ß",
			"5": "ůį≤©",
			"6": "ůį≤ę",
			"7": "ůį≤≠",
			"8": "ůį≤Į",
			"9": "ůį≤Ī",
			"10": "ůįŅ≠",
			"special": "ÓĽ©",
			"default": "ůįĽÉ",
			//"focused": "ůįģē",
			"persistent": "ůĪ®ß",
			"urgent": "ůįóĖ"
		},
		"format-alt-click": "click-right",
		"on-click": "activate",
		"on-click-middle": "close",
		"tooltip": true
	},
	"sway/scratchpad": {
    	//"interval": 1,
	    "format": "{icon}",
	    "format-alt": "{icon} {count}",
	    "show-empty": false,
	    "format-icons": [
			"",		// STRING EMPTY=HIDDEN
			"ÓĽ©"
		],
	    "tooltip-format": "{app}: {title}",
		"tooltip": true
	},
	"hyprland/workspaces": {
	//"wlr/workspaces": {
    	//"interval": 1,
		"disable-scroll": false,
		"active-only": false,
		"all-outputs": true,
		"current-only": true,
		"sort-by-number": true,
		"show-special": true,
		"format": "{icon}",
		"format-icons": {
			"1": "ůį≤°",
			"2": "ůį≤£",
			"3": "ůį≤•",
			"4": "ůį≤ß",
			"5": "ůį≤©",
			"6": "ůį≤ę",
			"7": "ůį≤≠",
			"8": "ůį≤Į",
			"9": "ůį≤Ī",
			"10": "ůįŅ≠",
			"special": "ÓĽ©",
			"default": "ůįĽÉ",
			//"focused": "ůįģē",
			"persistent": "ůĪ®ß",
			"urgent": "ůįóĖ"
		},
		"format-alt-click": "click-right",
		"on-click": "activate",
		"on-click-middle": "close",
		"tooltip": true
	},
	"tray": {
    	//"interval": 1,
		"show-passive-items": true
	},
	"wlr/taskbar": {
    	//"interval": 1,
		"all-outputs": true,
		"markup": true,
		//"sort-by-app-id": true,		// 'old_link != NULL' failed //
		//"active-first": true,			// 'old_link != NULL' failed //
		"icon-theme": "Numix-Circle",
	    "format": "{icon}",
		//"format-icons": ["ůįł∂","ůįłł","ůįł∑","ůįłī","ůįłĶ","ůįł≥"],
	    "ignore-list": "$TERM",
		"on-click": "activate",
	    "on-click-middle": "close",
	    "on-click-right": "minimize-raise",
		"tooltip-format": "{title}",
		"tooltip": true
	},
	"gamemode": {
    	//"interval": 1,
		"format": "{glyph}",
		"format-alt": "{glyph} {count}",
		"format-alt-click": "click-right",
		//"glyph": "ůįäī",		// ONE OR THE OTHER //
		"use-icon": true,		// ONE OR THE OTHER //
		"hide-not-running": true,
		"icon-name": "input-gaming-symbolic",
		"tooltip-format": "Running:\t{count}",
		"tooltip": true
	},
	"custom/recorder": {
    	//"interval": 1,
		"on-click": "wf-recorder-gui",
		"on-click-middle": "flameshot screen",
		"on-click-right": "obs",
		//"interval": 1,
		//"exec-if": "[ -f $HOME/.config/waybar/SCRIPTS/RECORDER ]",
		//"exec": "$HOME/.config/waybar/SCRIPTS/RECORDER status",
		"format": "ůįĄĄ",
		//"format-alt": "ůįĄĄ '{}'",		// WIP ~ REPORT WHICH APP'S RECORDING
		//"format-alt-click": "click-right",
		//"on-click": "$HOME/.config/waybar/SCRIPTS/RECORDER toggle fullscreen",
		//"on-click-middle": "obs",
		//"on-click-right": "$HOME/.config/waybar/SCRIPTS/RECORDER toggle region",
		//"tooltip-format": "{}\n‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ\nūüĖĪŠź©‚Ě∂‚ćÜFULLSCREEN\nūüĖĪŠź©‚Ě∑‚ćÜREGION\nūüĖĪŠź©‚Ěł‚ćÜOBS'",
		//"tooltip-format": "ÔÄį:\t{CAMERA}\nÔČ¨Ôäć:\t{SCREEN}",	// WIP ~ REPORT CAMERA/SCREEN/APPLICATION/REGION
		"tooltip-format": "{}\n‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ\nūüĖĪŠź©‚Ě∂‚ćÜwf-recorder-gui\nūüĖĪŠź©‚Ě∑‚ćÜobs-studio\nūüĖĪŠź©‚Ěł‚ćÜflameshot-git'",
		"tooltip": true
		//"return-type": "json"
	},
/*‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ(MODULES_CENTER)‚ĒÄ‚ĒÄ‚ĒÄ*/
	"custom/weather": {
    	"interval": 3600,
    	"exec-if": "which wttrbar",
    	"exec": "wttrbar --fahrenheit", //"temp1=$(wttrbar --fahrenheit); temp2=$(wttrbar); echo {\"temp1\":\"$temp1\", \"temp2\":\"$temp2\"}",
    	"format": "{}ÓćĀ",
    	"format-alt": "{}ÓĆĻ",
    	"format-alt-click": "click-right",
    	"on-click": "exec",
    	"on-click-middle": "xdg-open https://wttr.in",
    	"tooltip": true,
    	"return-type": "json"
	},
	"custom/notification": {
		//"interval": 1,
		"exec-if": "which swaync-client",
		"exec": "swaync-client -swb",
		"format": "{icon}",
		"format-alt": "{}",
		"format-alt-click": "click-right",
		"format-icons": {
			"none": "ůįĶõ",
			"notification": "ůįāě",
			"dnd-none": "ůįāõ",
			"dnd-notification": "Ôá∂",
			"inhibited-none": "Ôíö",
			"inhibited-notification": "Óģö",
			"dnd-inhibited-none": "ÔĎł",
			"dnd-inhibited-notification": "ÓįČ"
		},
		"on-click": "swaync-client -R -rs && swaync-client -t -swb",
		"on-click-middle": "swaync-client -d -swb",
		"escape": true,
		"tooltip": true,
		"return-type": "json"
	},
	"group/music": {
		"all-outputs": true,
		"orientation": "horizontal",
		"drawer": {
			"children-class": "options",
    	    "transition-left-to-right": false
		},
		"modules": [
			"mpd",				// AUR: MPD
			"cava",				// AUR: WAYBAR-CAVA
			"custom/cava"		// WIP SCRIPT: $HOME/.CONFIG/WAYBAR/SCRIPTS/CAVA
		]
	},
	"custom/cava": {	// WIP ~ IMPORT/EXPORT TO/FROM SCRIPT
		"interval": 1,
		"exec-if": "[ -f $HOME/.config/waybar/SCRIPTS/CAVA ]",
		"exec": "$HOME/.config/waybar/SCRIPTS/CAVA",
		//"config": "$HOME/.config/cava/config",
		"format": "‚Ėē{}‚ĖŹ",
		"format-icons" : ["‚ĖĀ","‚Ėā","‚ĖÉ","‚ĖĄ","‚ĖÖ","‚ĖÜ","‚Ėá","‚Ėą"],
		//"bars": 10,
		//"bar_delimiter": 0,
		"on-click": "playerctl play-pause",		//"mpris-ctl pp",
		"on-click-middle": "playerctl open",	//"mpris-ctl raise",
		"on-scroll-up": "playerctl previous",	//"mpris-ctl previous",
		"on-scroll-down": "playerctl next",		//"mpris-ctl next",
		"tooltip-format": "ÔÖĄ\t{playerName}\nūüéú\t{artist} ūüĘĖ {title}",
		"tooltip": true,	// ?TRUE BREAKS ALL MODULE TOOLTIPS?
		"return": "json"
	},
	"cava": {
		"interval": 1,
		"cava_config": "$HOME/.config/cava/config",
		"framerate": 240,
		"autosens": 1,
		//"sensitivity": 100,
		"bars": 8,
		//"lower_cutoff_freq": 50,
		//"higher_cutoff_freq": 10000,
		//"method": "auto",
		//"source": "auto",
		//"stereo": true,
		//"reverse": false,
		"bar_delimiter": 0,
		//"monstercat": false,
		//"waves": false,
		//"noise_reduction": 0.77,
		//"input_delay": 2,
		"format-icons" : ["‚ĖĀ","‚Ėā","‚ĖÉ","‚ĖĄ","‚ĖÖ","‚ĖÜ","‚Ėá","‚Ėą"],
		"on-click": "playerctl play-pause",		//"mpris-ctl pp",
		"on-click-middle": "playerctl open",	//"mpris-ctl raise",
		"on-click-right": "mode",
		"on-scroll-up": "playerctl previous",	//"mpris-ctl previous",
		"on-scroll-down": "playerctl next",		//"mpris-ctl next",
		"tooltip-format": "ÔÖĄ\t{playerName}\nūüéú\t{artist} ūüĘĖ {title}",
		"tooltip": true,	// ?TRUE BREAKS ALL MODULE TOOLTIPS?
		"return": "json"
    },
	"mpd": {
		"interval": 1,
		//"title-len": 34,
		"unknown-tag": "ůĪĄ∂",
		"format": "ůįęĒ",
		"format-alt": "{consumeIcon}{singleIcon}{artist} - {title} ůįęĒ {stateIcon}",
		"format-disconnected": "ůįĹ≥",
		"format-stopped": "{consumeIcon}{singleIcon}",
		"consume-icons": {
			"on": "ůįźć"
		},
		"random-icons": {
			"on": "ůįźć"
		},
		"repeat-icons": {
			"on": "ůįźć"
		},
		"single-icons": {
			"off": "ůįĹ≥",
			"on": "ůįźć"
		},
		"state-icons": {
			"paused": "ůįŹ¶",
			"playing": "ůįźć"
		},
		"on-click": "playerctl play-pause",		//"mpris-ctl pp",
		"on-click-middle": "playerctl open",	//"mpris-ctl raise",
		"on-scroll-up": "playerctl previous",	//"mpris-ctl previous",
		"on-scroll-down": "playerctl next",		//"mpris-ctl next",
		"tooltip-format": "ÔÖĄ\t{playerName}\nūüéú\t{artist} ūüĘĖ {title}",
		"tooltip-format-disconnected": "ůįĹ≥",
		"tooltip": true
	},
	"clock": {
		"interval": 1,
		"format": "{:%Z:%T} ůĪõ°",
		"format-alt": "{:%a:%D} ůĪõ°",
		"format-alt-click": "click-right",
		"calendar": {
			"mode"			: "year",
			"mode-mon-col"	: 2,
			"weeks-pos"		: "left",
			"on-scroll"		: 1,
			"on-click-right": "mode",
			"format": {
				"months"	: "<span color='#FFFFFF'><b>{}</b></span>",
				"days"		: "<span color='#444444'><b>{}</b></span>",
				"weeks"		: "<span color='#AAAAAA'><b>{}</b></span>",
				"weekdays"	: "<span color='#AAAAAA'><b>{}</b></span>",
				"today"		: "<span color='#FFFFFF'><b>{}</b></span>"
			}
		},
		"actions": {
			"on-click-right"	: "mode",
			"on-click-forward"	: "tz_up",
			"on-click-backward"	: "tz_down",
			"on-scroll-up"		: "shift_down",
			"on-scroll-down"	: "shift_up"
		},
		"on-click": "wl-copy $(date '+%F_%T')",
		"on-click-middle": "betterbird -calendar",
		"tooltip-format": "{calendar}",
		"tooltip": true
	},
/*‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ(MODULES_RIGHT)‚ĒÄ‚ĒÄ‚ĒÄ*/
	"group/window": {
		//"interval": 1,
		"all-outputs": true,
		"orientation": "horizontal",
		"drawer": {
			"children-class": "options",
    	    "transition-left-to-right": false
		},
		"modules": [
			"idle_inhibitor",
			"wlr/window",
			"sway/window",
			"hyprland/window"
		]
	},
	"hyprland/window": {
	//"wlr/window": {
		//"interval": 1,
		"format": "{}",
		"separate-outputs": true,
		"rewrite": {
			"(.*) - Mozilla Firefox": "Ôā¨ $1",
			"(.*) - Brave": "Ôā¨ $1",
			"(.*) - xterm": "ÔĄ† [$1]"
		},
		"tooltip": true
	},
	"sway/window": {
		//"interval": 1,
		"format": "{}",
		"separate-outputs": true,
		"rewrite": {
			"(.*) - Mozilla Firefox": "Ôā¨ $1",
			"(.*) - Brave": "Ôā¨ $1",
