#!/bin/bash

# Define constants
NAMESPACE="anonspace"
VETH_NAME="veth0"
VETH_PEER="veth1"
VPN_SERVER="your.vpn.server"
VPN_PORT="443"
INTERFACE="wg0"
WIREPROXY_CONFIG_DIR="$HOME/.config/wireproxy"
WIREPROXY_CONFIG_FILE="$WIREPROXY_CONFIG_DIR/config.toml"
TOR_CONFIG_FILE="/etc/tor/torrc"
TOR_SERVICE="/etc/systemd/system/tor.service"
WIREPROXY_SERVICE="$HOME/.config/systemd/user/wireproxy.service"
SHADOWSOCKS_CONFIG="$HOME/.config/shadowsocks.json"
I2P_CONFIG_DIR="$HOME/.config/.i2p"

# Function to detect the OS and package manager
detect_os_and_package_manager() {
    if [ -f /etc/os-release ]; then
        # Check for supported Linux distros
        source /etc/os-release
        OS_NAME=$ID
        case $OS_NAME in
            "debian")
                PACKAGE_MANAGER="apt"
                ;;
            "fedora")
                PACKAGE_MANAGER="dnf"
                ;;
            "arch")
                PACKAGE_MANAGER="pacman"
                ;;
            "macos")
                PACKAGE_MANAGER="brew"
                ;;
            *)
                echo "Unsupported OS: $OS_NAME"
                exit 1
                ;;
        esac
    else
        echo "OS detection failed. Ensure this is a Linux or macOS system."
        exit 1
    fi
}

# Function to check and install missing tools
check_and_install_tools() {
    declare -A tools
    tools=(
        ["WireGuard"]="wireguard-tools"
        ["Tor"]="tor"
        ["Shadowsocks"]="shadowsocks-libev"
        ["I2P"]="i2p"
        ["WireProxy"]="wireproxy"
    )

    missing_tools=()

    # Check if each tool is installed
    for tool in "${!tools[@]}"; do
        if ! command -v ${tool,,} &>/dev/null; then
            missing_tools+=("$tool")
        fi
    done

    if [ ${#missing_tools[@]} -gt 0 ]; then
        echo "Missing tools: ${missing_tools[@]}"
        echo "Would you like to install them? (y/n)"
        read -p "Enter your choice: " install_choice
        if [[ "$install_choice" == "y" || "$install_choice" == "Y" ]]; then
            for tool in "${missing_tools[@]}"; do
                echo "Would you like to install $tool? (y/n)"
                read -p "Enter your choice for $tool: " choice
                if [[ "$choice" == "y" || "$choice" == "Y" ]]; then
                    install_package "${tools[$tool]}"
                fi
            done
        else
            echo "Installation aborted. Exiting..."
            exit 1
        fi
    else
        echo "All required tools are already installed."
    fi
}

# Function to install a package using the correct package manager
install_package() {
    local package=$1
    echo "Installing $package using $PACKAGE_MANAGER..."

    case $PACKAGE_MANAGER in
        "apt")
            sudo apt update && sudo apt install -y $package
            ;;
        "dnf")
            sudo dnf install -y $package
            ;;
        "pacman")
            sudo pacman -S $package
            ;;
        "brew")
            brew install $package
            ;;
        *)
            echo "Unsupported package manager: $PACKAGE_MANAGER"
            exit 1
            ;;
    esac
}

# Function to create network namespace for isolation
create_namespace() {
    echo "Creating network namespace '$NAMESPACE'..."
    sudo ip netns add $NAMESPACE
    sudo ip link add $VETH_NAME type veth peer name $VETH_PEER
    sudo ip link set $VETH_PEER netns $NAMESPACE
    sudo ip addr add 10.200.200.1/24 dev $VETH_NAME
    sudo ip link set $VETH_NAME up
    sudo ip netns exec $NAMESPACE ip addr add 10.200.200.2/24 dev $VETH_PEER
    sudo ip netns exec $NAMESPACE ip link set $VETH_PEER up
    sudo ip netns exec $NAMESPACE ip link set lo up
    sudo ip netns exec $NAMESPACE ip route add default via 10.200.200.1
    echo "Network namespace '$NAMESPACE' created and configured."
}

# Function to configure WireProxy
configure_wireproxy() {
    echo "Configuring WireProxy..."
    mkdir -p $WIREPROXY_CONFIG_DIR
    cat <<EOF > $WIREPROXY_CONFIG_FILE
[Interface]
PrivateKey = YOUR_PRIVATE_KEY
Address = 10.66.66.2/24
DNS = 1.1.1.1

[Peer]
PublicKey = YOUR_SERVER_PUBLIC_KEY
Endpoint = $VPN_SERVER:$VPN_PORT
AllowedIPs = 0.0.0.0/0
PersistentKeepalive = 25
EOF
    echo "WireProxy configuration created."
}

# Function to start WireProxy service
start_wireproxy_service() {
    echo "Starting WireProxy service..."
    systemctl --user daemon-reload
    systemctl --user enable --now wireproxy.service
}

# Function to configure Tor
configure_tor() {
    echo "Configuring Tor with obfs4 bridge..."
    cat <<EOF > $TOR_CONFIG_FILE
UseBridges 1
ClientTransportPlugin obfs4 exec /usr/bin/obfs4proxy
Bridge obfs4 $TOR_BRIDGE_IP:$TOR_BRIDGE_PORT $TOR_BRIDGE_FINGERPRINT cert=$TOR_BRIDGE_CERT iat-mode=0
SOCKSPort 9050
DNSPort 5353
VirtualAddrNetworkIPv4 10.192.0.0/10
AutomapHostsOnResolve 1
TransPort 9040
TransListenAddress 127.0.0.1
DNSListenAddress 127.0.0.1
ExitRelay 0
StrictNodes 1
EOF
    echo "Tor configuration created."
}

# Function to start Tor service
start_tor_service() {
    echo "Starting Tor service..."
    sudo systemctl daemon-reload
    sudo systemctl enable --now tor.service
}

# Function to configure Shadowsocks
configure_shadowsocks() {
    echo "Configuring Shadowsocks..."
    cat <<EOF > $SHADOWSOCKS_CONFIG
{
    "server": "$VPN_SERVER",
    "server_port": $VPN_PORT,
    "local_address": "127.0.0.1",
    "local_port": 1080,
    "password": "$SS_PASSWORD",
    "timeout": 300,
    "method": "aes-256-cfb"
}
EOF
    echo "Shadowsocks configuration created."
}

# Function to start Shadowsocks service
start_shadowsocks_service() {
    echo "Starting Shadowsocks service..."
    ss-local -c $SHADOWSOCKS_CONFIG &
}

# Function to configure I2P
configure_i2p() {
    echo "Configuring I2P..."
    mkdir -p $I2P_CONFIG_DIR
    # Example configuration for I2P (Modify as needed)
    cat <<EOF > $I2P_CONFIG_DIR/i2p.conf
# I2P configuration
# Please modify this file with your I2P server settings
# For I2P, you need to start the router service and configure tunnels
EOF
    echo "I2P configuration created."
}

# Function to start I2P service
start_i2p_service() {
    echo "Starting I2P service..."
    sudo systemctl start i2p
}

# Apply firewall and routing rules based on selected tool
apply_routing_and_firewall() {
    echo "Configuring routing and firewall..."

    sudo sysctl -w net.ipv4.ip_forward=1
    sudo iptables -t nat -A POSTROUTING -s 10.200.200.0/24 -o $INTERFACE -j MASQUERADE
    sudo iptables -A FORWARD -i $INTERFACE -o $VETH_NAME -j ACCEPT
    sudo iptables -A FORWARD -i $VETH_NAME -o $INTERFACE -j ACCEPT

    # Redirect all DNS queries through Tor or WireGuard
    if [ "$selected_tool" == "Tor" ]; then
        sudo iptables -t nat -A PREROUTING -p udp --dport 53 -j REDIRECT --to-ports 5353
        sudo iptables -t nat -A PREROUTING -p tcp --dport 53 -j REDIRECT --to-ports 5353
    fi

    echo "Routing and firewall rules applied."
}

# Function to start the selected tool based on user's choice
start_selected_tool() {

    clear
    echo -e "\n(; OG_EVAH_NUF\N"

    case "$selected_tool" in
        "WireGuard")
            configure_wireproxy
            start_wireproxy_service
            ;;
        "Tor")
            configure_tor
            start_tor_service
            ;;
        "Shadowsocks")
            configure_shadowsocks
            start_shadowsocks_service
            ;;
        "I2P")
            configure_i2p
            start_i2p_service
            ;;
        *)
            echo "Unknown tool selected."
            exit 1
            ;;
    esac
}

# Main entry point
main() {
    # Step 1: Detect OS and package manager
    detect_os_and_package_manager

    # Step 2: Check for missing tools and offer installation
    check_and_install_tools

    # Step 3: Create network namespace for isolation
    create_namespace

    # Step 4: Apply routing and firewall rules
    apply_routing_and_firewall

    # Step 5: Start the selected tool (WireGuard, Tor, or Shadowsocks)
    start_selected_tool

    echo "Anonymity setup is complete and active."
}

# Start the script
main
