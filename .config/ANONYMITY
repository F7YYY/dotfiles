#!/usr/bin/env bash
# Strict mode: fail on errors, undefined vars, and pipe failures
set -euo pipefail
IFS=$'\n\t'

###################
# Constants / Defaults
###################

readonly NAMESPACE="anonspace"
readonly VETH_NAME="veth0"
readonly VETH_PEER="veth1"
readonly DEFAULT_CIDR="10.200.200.0/24"
readonly VPN_SERVER=""
readonly VPN_PORT="443"
readonly INTERFACE="wg0"

# config paths
readonly WP_CONFIG_DIR="$HOME/.config/wireproxy"
readonly WP_CONFIG_FILE="$WP_CONFIG_DIR/config.toml"
readonly TOR_CONFIG_FILE="/etc/tor/torrc"
readonly SHADOWSOCKS_CONFIG="$HOME/.config/shadowsocks.json"
readonly I2P_CONFIG_DIR="$HOME/.config/i2p"

###################
# Helpers
###################

die() {
    echo "ERROR: $1" >&2
    exit 1
}

prompt_yesno() {
    local prompt="$1"
    local ans
    read -rp "$prompt (y/N): " ans
    [[ "$ans" =~ ^[Yy]$ ]]
}

###################
# Detect OS + Package Manager
###################

detect_os_and_package_manager() {
    if [[ -f /etc/os-release ]]; then
        source /etc/os-release
        case "${ID,,}" in
            ubuntu|debian*)
                PACKAGE_MANAGER="apt"
                ;;
            fedora*|centos*|rocky*)
                PACKAGE_MANAGER="dnf"
                ;;
            arch)
                PACKAGE_MANAGER="pacman"
                ;;
            *)
                die "Unsupported OS: $ID"
                ;;
        esac
    else
        die "OS detection failed"
    fi
}

install_package() {
    local pkg="$1"
    case "$PACKAGE_MANAGER" in
        apt)
            sudo apt update && sudo apt install -y "$pkg"
            ;;
        dnf)
            sudo dnf install -y "$pkg"
            ;;
        pacman)
            sudo pacman -Sy --noconfirm "$pkg"
            ;;
        *)
            die "Unsupported package manager: $PACKAGE_MANAGER"
            ;;
    esac
}

###################
# Check & install tools
###################

check_and_install_tools() {
    declare -A tools=(
        ["wg"]="wireguard-tools"
        ["tor"]="tor"
        ["ss-local"]="shadowsocks-libev"
        ["i2prouter"]="i2p"
        ["wireproxy"]="wireproxy"
    )

    local missing=()

    for cmd in "${!tools[@]}"; do
        if ! command -v "$cmd" &> /dev/null; then
            missing+=("$cmd")
        fi
    done

    if [[ ${#missing[@]} -gt 0 ]]; then
        echo "Missing: ${missing[*]}"
        if prompt_yesno "Install missing tools?"; then
            for cmd in "${missing[@]}"; do
                install_package "${tools[$cmd]}"
            done
        else
            die "Required tools missing"
        fi
    fi
}

###################
# Cleanup everything
###################

cleanup() {
    echo "Cleaning up..."

    # Remove firewall rules (flush NAT and filter rules)
    sudo iptables -t nat -F
    sudo iptables -F
    sudo iptables -X
    sudo iptables -P INPUT ACCEPT
    sudo iptables -P OUTPUT ACCEPT
    sudo iptables -P FORWARD ACCEPT

    # Delete network namespace and veth interface
    sudo ip netns delete "$NAMESPACE" 2>/dev/null || true
    sudo ip link delete "$VETH_NAME" 2>/dev/null || true

    # Stop/disable services
    systemctl --user disable --now wireproxy.service 2>/dev/null || true
    sudo systemctl disable --now tor.service 2>/dev/null || true

    echo "Cleanup complete."
}

###################
# Network Namespace Setup
###################

create_namespace() {
    echo "Creating namespace..."
    # Cleanup old namespace if exists
    sudo ip netns delete "$NAMESPACE" 2>/dev/null || true
    sudo ip link delete "$VETH_NAME" 2>/dev/null || true

    sudo ip netns add "$NAMESPACE"
    sudo ip link add "$VETH_NAME" type veth peer name "$VETH_PEER"
    sudo ip link set "$VETH_PEER" netns "$NAMESPACE"

    sudo ip addr add "${DEFAULT_CIDR%.*}.1/24" dev "$VETH_NAME"
    sudo ip link set "$VETH_NAME" up

    sudo ip netns exec "$NAMESPACE" ip addr add "${DEFAULT_CIDR%.*}.2/24" dev "$VETH_PEER"
    sudo ip netns exec "$NAMESPACE" ip link set lo up
    sudo ip netns exec "$NAMESPACE" ip link set "$VETH_PEER" up
    sudo ip netns exec "$NAMESPACE" ip route add default via "${DEFAULT_CIDR%.*}.1"
}

###################
# WireProxy (WireGuard)
###################

configure_wireproxy() {
    mkdir -p "$WP_CONFIG_DIR"
    cat > "$WP_CONFIG_FILE" <<EOF
[Interface]
PrivateKey = YOUR_PRIVATE_KEY
Address = 10.66.66.2/24
DNS = 1.1.1.1

[Peer]
PublicKey = YOUR_SERVER_PUBLIC_KEY
Endpoint = $VPN_SERVER:$VPN_PORT
AllowedIPs = 0.0.0.0/0
EOF
}

start_wireproxy_service() {
    systemctl --user daemon-reload
    systemctl --user enable --now wireproxy.service
}

###################
# Tor
###################

configure_tor() {
    sudo mkdir -p "$(dirname "$TOR_CONFIG_FILE")"
    sudo tee "$TOR_CONFIG_FILE" > /dev/null <<EOF
UseBridges 1
ClientTransportPlugin obfs4 exec /usr/bin/obfs4proxy
# Define real bridge values below
SOCKSPort 9050
EOF
}

start_tor_service() {
    sudo systemctl daemon-reload
    sudo systemctl enable --now tor.service
}

###################
# Shadowsocks
###################

configure_shadowsocks() {
    read -rp "Shadowsocks password: " -s SS_PASSWORD
    mkdir -p "$(dirname "$SHADOWSOCKS_CONFIG")"
    cat > "$SHADOWSOCKS_CONFIG" <<EOF
{
  "server":"$VPN_SERVER",
  "server_port":$VPN_PORT,
  "local_port":1080,
  "password":"$SS_PASSWORD",
  "method":"aes-256-gcm"
}
EOF
}

start_shadowsocks_service() {
    nohup ss-local -c "$SHADOWSOCKS_CONFIG" &>/dev/null &
}

###################
# I2P
###################

configure_i2p() {
    mkdir -p "$I2P_CONFIG_DIR"
    cat > "$I2P_CONFIG_DIR/i2p.conf" <<EOF
# I2P config
EOF
}

start_i2p_service() {
    sudo systemctl enable --now i2p
}

###################
# Firewall + Routing
###################

apply_routing_and_firewall() {
    echo "Applying firewall rules..."
    sudo sysctl -w net.ipv4.ip_forward=1
    sudo iptables -t nat -A POSTROUTING -s "$DEFAULT_CIDR" -o "$INTERFACE" -j MASQUERADE
    sudo iptables -A FORWARD -i "$INTERFACE" -o "$VETH_NAME" -j ACCEPT
    sudo iptables -A FORWARD -i "$VETH_NAME" -o "$INTERFACE" -j ACCEPT
}

###################
# Main
###################

main() {
    detect_os_and_package_manager

    echo "Select an action:"
    echo "  1) Setup anonymity tools"
    echo "  2) Cleanup / undo setup"

    read -rp "Enter choice [1-2]: " action_choice

    case "$action_choice" in
        2)
            cleanup
            exit 0
            ;;
        1)
            ;;
        *)
            echo "Invalid option"
            exit 1
            ;;
    esac

    #check_and_install_tools

    echo "Select tool to enable:"
    select selected_tool in "WireGuard" "Tor" "Shadowsocks" "I2P"; do
        [[ -n "$selected_tool" ]] && break
        echo "Invalid choice"
    done

    create_namespace
    apply_routing_and_firewall

    case "$selected_tool" in
        "WireGuard")
            read -rp "Enter VPN server (host): " VPN_SERVER
            configure_wireproxy
            start_wireproxy_service
            ;;
        "Tor")
            configure_tor
            start_tor_service
            ;;
        "Shadowsocks")
            configure_shadowsocks
            start_shadowsocks_service
            ;;
        "I2P")
            configure_i2p
            start_i2p_service
            ;;
    esac

    echo "Setup complete!"
}

main
